AGENTBUS_REDIS_IMAGE=redis:8.8.0-alpine
AGENTBUS_REDIS_BIND=127.0.0.1
AGENTBUS_REDIS_PORT=6389
AGENTBUS_NS=agentbus:v1

# Container runtime is auto-detected (docker or podman): the one that runs the
# container wins. Uncomment to force a choice, e.g. on a machine with both.
# AGENTBUS_CONTAINER_RUNTIME=podman
# AGENTBUS_CONTAINER=agentbus-redis
